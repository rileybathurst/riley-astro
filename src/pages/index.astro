---
import Layout from "../components/layout.astro";
import fetchApi from "../lib/strapi";
import {
  BlocksRenderer,
  type BlocksContent,
} from "@strapi/blocks-react-renderer";

type clientType = {
  id: number;
  name: string;
  slug: string;
  order: number;
  svg: string;
};
const clients: clientType[] = await fetchApi({
  endpoint: "clients", // the content type to fetch
  limit: {
    field: "order",
    number: 10,
    order: "asc",
  },
  more: false,
});

type aboutType = {
  id: number;
  name: string;
  description: BlocksContent;
};
const about: aboutType = await fetchApi({
  endpoint: "about", // the content type to fetch
  more: false,
});
---

<Layout>
  <main>
    <section>
      <BlocksRenderer content={about.description} />

      <hr />
    </section>

    <section>
      <h1>
        <a href="/client">Clients</a>
      </h1>

      <ul>
        {
          clients.map((client: clientType) => (
            <li>
              {/* // * in Astro, set:html is the equivalent of React’s dangerouslySetInnerHTML. */}
              <div set:html={client.svg} aria-hidden="true" />
              <h2>
                <a href={`/client/${client.slug}`}>{client.name}</a>
              </h2>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
