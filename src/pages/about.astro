---
import Layout from "../components/layout.astro";
import {
  BlocksRenderer,
  type BlocksContent,
} from "@strapi/blocks-react-renderer";
import fetchApi from "../lib/strapi";

type aboutTypes = {
  me: BlocksContent;
};
const about: aboutTypes = await fetchApi({
  endpoint: "about", // the content type to fetch

  more: false,
});

// console.log(about);
---

<Layout title="About">
  <main>
    <h1>About</h1>
    <BlocksRenderer content={about.me} />
  </main>
</Layout>
