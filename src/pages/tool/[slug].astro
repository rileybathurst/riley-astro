---
import Layout from "../../components/layout.astro";
import fetchApi from "../../lib/strapi";

type toolTypes = {
  name: string;
  slug: string;
};

export async function getStaticPaths() {
  const tools = await fetchApi<toolTypes[]>({
    endpoint: "tools",
  });

  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: tool,
  }));
}
const tool = Astro.props;
---

<Layout>
  <main class="gutters">
    <h1 class="fore">{tool.name}</h1>
    <article class="cover split"></article>
  </main></Layout
>
