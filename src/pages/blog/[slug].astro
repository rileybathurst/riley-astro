---
import Layout from "../../components/layout.astro";
import fetchApi from "../../lib/strapi";
import {
  BlocksRenderer,
  type BlocksContent,
} from "@strapi/blocks-react-renderer";

type blogTypes = {
  title: string;
  slug: string;
  article: BlocksContent;
  tools?: {
    name: string;
    url?: string;
  }[];
};

export async function getStaticPaths() {
  const blogs = await fetchApi<blogTypes[]>({
    endpoint: "blogs",
    fields: ["tools"],
  });

  return blogs.map((blog) => ({
    params: { slug: blog.slug },
    props: blog,
  }));
}
const blog = Astro.props;
---

<!-- TODO: excerpt in SEO --><!-- TODO: image in header -->
<Layout title={blog.title}>
  <main>
    <!-- <h1 class="fore">{blog.title}</h1> -->

    <section class="cover split">
      <article>
        <BlocksRenderer content={blog.article} />
      </article>

      <div>
        {
          blog.tools && (
            <div>
              <h2>Tools</h2>
              {blog.tools.map((tool) => (
                <p>
                  <a href={`/tool/${tool.url}`}>{tool.name}</a>
                </p>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>
