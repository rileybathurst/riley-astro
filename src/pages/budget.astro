---
import Layout from "../components/layout.astro";
import {
  BlocksRenderer,
  type BlocksContent,
} from "@strapi/blocks-react-renderer";
import fetchApi from "../lib/strapi";
import type React from "react";

type budgetsTypes = {
  id: React.Key;
  service: string;
  description: BlocksContent;
}[];
const budgets: budgetsTypes = await fetchApi({
  endpoint: "budgets", // the content type to fetch

  more: false,
});
---

<Layout title="Budget">
  <main class="gutters">
    <h1 class="fore">Budget</h1>
    <section class="cover split">
      <div>
        {
          budgets.map((budget) => (
            <article>
              <h2>{budget.service}</h2>
              <BlocksRenderer content={budget.description} />
              <hr />
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
