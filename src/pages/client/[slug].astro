---
import Layout from "../../components/layout.astro";
import fetchApi from "../../lib/strapi";

type clientTypes = {
  name: string;
  slug: string;
  role: string;
  description: string;
  website: string;
  start: string;
  end: string;
  current: boolean;
  alive: boolean;
  projects: {
    title: string;
    slug: string;
  }[];
  hero?: {
    url: string;
  };
};

export async function getStaticPaths() {
  const clients = await fetchApi<clientTypes[]>({
    endpoint: "clients", // the content type to fetch
    fields: ["projects", "hero"],
  });

  return clients.map((client) => ({
    params: { slug: client.slug },
    props: client,
  }));
}

const client = Astro.props;
---

<Layout
  title={client.name}
  breadcrumbs={[{ title: "Client", slug: "client" }]}
  hero={client.hero?.url}
>
  <main class="gutters">
    <h1 class="fore">{client.name}</h1>

    <section class="cover split">
      <div>
        <h1>{client.name}</h1>
        <p>{client.description}</p>
        <p><a href={client.website}>{client.website}</a></p>
        <p>
          {client.role && <h2>Role - {client.role}</h2>}
        </p>
        {
          (client.start || client.end || client.current || client.alive) && (
            <p>
              I've been working with {client.name} since{" "}
              <code>{client.start}</code>
            </p>
          )
        }
      </div>
      <div>
        <h2>Projects</h2>
        {
          client.projects.map((project) => (
            <article>
              <h3>
                {/* // TODO: Figure out the slug of a project, if its behind a client but some dont have clients  */}
                <a href={`/project/${project.slug}`}>{project.title}</a>
              </h3>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
