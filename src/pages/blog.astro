---
import Trailhead from "../templates/trailhead.astro";
import fetchApi from "../lib/strapi";

type blogTypes = {
  title: string;
  slug: string;
};
const blogs: blogTypes[] = await fetchApi({
  endpoint: "blogs",
});

console.log(blogs);
---

<Trailhead trail="Blog" paths={blogs} breadcrumb="blog" />
