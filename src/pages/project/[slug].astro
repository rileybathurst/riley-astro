---
import Layout from "../../components/layout.astro";
import fetchApi from "../../lib/strapi";
import {
  BlocksRenderer,
  type BlocksContent,
} from "@strapi/blocks-react-renderer";

// import { YouTube } from 'astro-embed';

type projectTypes = {
  title: string;
  slug: string;
  client?: {
    name: string;
    slug: string;
  };
  hero: {
    url: string;
  };
  embed?: string;
  link?: {
    link: string;
    platform: {
      name: string;
      svg: string;
    };
  }[];
  description: BlocksContent;
  personal: BlocksContent;
  trades?: {
    name: string;
  }[];
};

export async function getStaticPaths() {
  const projects = await fetchApi<projectTypes[]>({
    endpoint: "projects", // the content type to fetch

    fields: ["client", "trades", "tools", "link", "link.platform", "hero"],
    // more: true,
  });

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

const project = Astro.props;

const clientName = project.client?.name?.trim();
const shortTitle =
  clientName && project.title.startsWith(clientName)
    ? project.title
        .slice(clientName.length)
        .replace(/^[\s:,-]+/, "")
        .trim()
    : project.title;
---

<Layout
  title={shortTitle}
  breadcrumbs={[
    { title: "Clients", slug: "client" },
    ...(project.client
      ? [{ title: project.client.name, slug: project.client.slug }]
      : []),
  ]}
  {...project.hero && { hero: project.hero.url }}
  {...project.embed && { embed: project.embed }}
>
  <main>
    <section class="cover split">
      <div>
        <h1>{shortTitle}</h1>
        <h2>
          Client -
          <a href={`/client/${project.client?.slug}`}>
            {project.client?.name}
          </a>
        </h2>
        {
          project.link && (
            <ul class="blocks">
              {project.link.map((link) => (
                <li>
                  <a href={link.link}>
                    <div set:html={link.platform.svg} aria-hidden="true" />
                    <span class="sr-only">{link.platform.name}</span>
                  </a>
                </li>
              ))}
            </ul>
          )
        }

        <!-- TODO: I dont really know what im going with here -->
        {
          project.trades && (
            <p>
              Trades:{" "}
              {project.trades.map((trade) => (
                <span>{trade.name} </span>
              ))}
            </p>
          )
        }

        {
          project.description && (
            <BlocksRenderer content={project.description} />
          )
        }
      </div>

      <div>
        {project.personal && <BlocksRenderer content={project.personal} />}
      </div>

      <!--
      {
        (() => {
          const url = project.link;
          if (!url || !url.includes("youtube")) return null;
          const match = url.match(
            /(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([A-Za-z0-9_-]{11})/,
          );
          if (!match) return null;
          // return <YouTube id={match[1]} />;
        })()
      } -->
    </section>
  </main>
</Layout>
