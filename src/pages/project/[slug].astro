---
import Layout from "../../components/layout.astro";
import fetchApi from "../../lib/strapi";
import {
  BlocksRenderer,
  type BlocksContent,
} from "@strapi/blocks-react-renderer";

// import { YouTube } from 'astro-embed';

type projectTypes = {
  title: string;
  slug: string;
  client?: {
    name: string;
    slug: string;
  };
  embed?: string;
  link?: string;
  description: BlocksContent;
};

export async function getStaticPaths() {
  const projects = await fetchApi<projectTypes[]>({
    endpoint: "projects", // the content type to fetch

    fields: ["client", "trades"],
    // more: true,
  });

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

const project = Astro.props;
---

<!-- TODO: --><!-- platforms --><!-- tools --><!-- trades -->
<Layout
  title={project.title}
  breadcrumbs={[
    { title: "Clients", slug: "client" },
    ...(project.client
      ? [{ title: project.client.name, slug: project.client.slug }]
      : []),
  ]}
  embed={project.embed}
>
  <main>
    <section class="cover split">
      <div>
        <h1>{project.title}</h1>
        <h2>
          Client -
          <a href={`/client/${project.client?.slug}`}>
            {project.client?.name}
          </a>
        </h2>
        {
          project.link && (
            <p>
              <a href={project.link}>{project.link}</a>
            </p>
          )
        }

        {
          project.trades && (
            <p>
              Trades:{" "}
              {project.trades.map((trade) => (
                <span>{trade.name} </span>
              ))}
            </p>
          )
        }

        <BlocksRenderer content={project.description} />
      </div>

      <div>
        <BlocksRenderer content={project.personal} />
      </div>

      <!--
      {
        (() => {
          const url = project.link;
          if (!url || !url.includes("youtube")) return null;
          const match = url.match(
            /(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([A-Za-z0-9_-]{11})/,
          );
          if (!match) return null;
          // return <YouTube id={match[1]} />;
        })()
      } -->
    </section>
  </main>
</Layout>
