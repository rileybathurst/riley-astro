---
import Layout from "../components/layout.astro";
import fetchApi from "../lib/strapi";

type toolTypes = {
  name: string;
  slug: string;
};
const tools: toolTypes[] = await fetchApi({
  endpoint: "tools", // the content type to fetch
  //
  // more: false,
});
---

<Layout>
  <main class="gutters">
    <h1 class="fore">tool</h1>
    <ul class="cover">
      {
        tools.map((tool) => (
          <li>
            <a href={`/tool/${tool.slug}`}>{tool.name}</a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
